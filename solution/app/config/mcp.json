{
  "servers": {
    "shopflow-sqlite": {
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", "${SHOPFLOW_DB}"],
      "transport": "stdio"
    },
    "datapilot-dq": {
      "command": "python",
      "args": ["solution/mcp_servers/dq_server.py", "${SHOPFLOW_DB}"],
      "transport": "stdio"
    }
  }
}
